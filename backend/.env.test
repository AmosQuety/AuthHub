NODE_ENV=test
PORT=3001

# Use a separate test database (or same Supabase with a test schema)
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres
DIRECT_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres

# Redis — CI spins up a real Redis service container
REDIS_URL=redis://localhost:6379

# JWT Keys — can use the same dev keys for tests
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nPASTE_KEY_HERE\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nPASTE_KEY_HERE\n-----END PUBLIC KEY-----"

ARGON2_PEPPER=test_pepper

BASE_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3002
ALLOWED_ORIGINS=http://localhost:3002

# SMTP — disabled in tests (sendMail is mocked)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=test
SMTP_PASS=test
SMTP_FROM="AuthHub Test <test@authhub.dev>"
