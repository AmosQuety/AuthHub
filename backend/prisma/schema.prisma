generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // DATABASE_URL → Supabase connection pooler (port 6543, transaction mode) — used at runtime
  url       = env("DATABASE_URL")
  // DIRECT_URL → Supabase direct connection (port 5432) — used by prisma migrate
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id             String         @id @default(uuid()) @db.Uuid
  email          String
  passwordHash   String?        @map("password_hash") // Optional for social login
  emailVerified  Boolean        @default(false) @map("email_verified")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  roles          Role[]         @default([USER])
  tenantId       String?        @map("tenant_id") @db.Uuid
  sessions       Session[]
  authProviders  AuthProvider[]
  ownedClients   OAuthClient[]
  mfaMethods     MfaMethod[]
  auditLogs      AuditLog[]
  consents       UserConsent[]
  entitlements   Entitlement[]
  tenant         Tenant?        @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  // Email unique per tenant — Alice can have separate accounts across different apps
  @@unique([email, tenantId])
  @@map("users")
}

model Session {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @db.Uuid @map("user_id")
  refreshTokenHash  String   @map("refresh_token_hash")
  deviceInfo        String?  @map("device_info")
  ipAddress         String?  @map("ip_address")
  familyId          String?  @map("family_id") // For refresh token sliding window/revocation
  riskScore         Int?     @map("risk_score") // Track risk of the login event
  expiresAt         DateTime @map("expires_at")
  createdAt         DateTime @default(now()) @map("created_at")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model OAuthClient {
  clientId          String   @id @map("client_id")
  clientSecretHash  String   @map("client_secret_hash")
  isPublic          Boolean  @default(false) @map("is_public")
  redirectUris      String[] @map("redirect_uris")
  scopes            String[] @default([])
  name              String
  tenantId          String?  @map("tenant_id") @db.Uuid
  ownerId           String?  @map("owner_id") @db.Uuid
  createdAt         DateTime @default(now()) @map("created_at")
  tenant            Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  owner             User?    @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  userConsents      UserConsent[]

  @@map("oauth_clients")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @db.Uuid @map("user_id") // Optional because anonymous actions (failed logins) still generate logs
  action    String   // e.g., "LOGIN_SUCCESS", "LOGIN_FAILED", "MFA_ENABLED", "PASSWORD_RESET"
  ipAddress String?  @map("ip_address")
  deviceInfo String? @map("device_info")
  status    String   // "SUCCESS", "FAILURE", "BLOCKED"
  details   Json?    // Extra contextual metadata
  createdAt DateTime @default(now()) @map("created_at")
  
  // Relations
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

model AuthProvider {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @db.Uuid @map("user_id")
  provider      String   // "google", "github", "apple"
  providerId    String   @map("provider_id") // ID from the third party
  providerEmail String?  @map("provider_email")
  createdAt     DateTime @default(now()) @map("created_at")

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@map("auth_providers")
}

model MfaMethod {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid @map("user_id")
  type      String   // "totp", "webauthn"
  secret    String   // TOTP secret or WebAuthn public key/credential ID
  enabled   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("mfa_methods")
}

model Tenant {
  id            String        @id @default(uuid()) @db.Uuid
  name          String
  clientId      String?       @unique @map("client_id")       // e.g. 'xemora_aB3kP9mNqR'
  customDomain  String?       @unique @map("custom_domain")   // e.g. 'auth.xemora.com'
  logoUrl       String?       @map("logo_url")
  primaryColor  String?       @map("primary_color")
  authPolicyId  String?       @map("auth_policy_id")
  requireMfa    Boolean       @default(false) @map("require_mfa")
  allowPasskeys Boolean       @default(true)  @map("allow_passkeys")
  // White-label SMTP — per-tenant transactional email config
  smtpHost      String?       @map("smtp_host")
  smtpPort      Int?          @map("smtp_port")
  smtpUser      String?       @map("smtp_user")
  smtpPassHash  String?       @map("smtp_pass_hash")          // stored encrypted, never plaintext
  emailFrom     String?       @map("email_from")              // e.g. 'noreply@xemora.com'
  // White-label webhook
  webhookUrl    String?       @map("webhook_url")
  webhookSecret String?       @map("webhook_secret")
  createdAt     DateTime      @default(now()) @map("created_at")
  clients       OAuthClient[]
  users         User[]

  @@map("tenants")
}

model UserConsent {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid @map("user_id")
  clientId  String   @map("client_id")
  scopes    String[] @default([])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  client OAuthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)

  // A user can only have one consent record per application
  @@unique([userId, clientId])
  @@map("user_consents")
}

model Entitlement {
  id                     String   @id @default(uuid()) @db.Uuid
  userId                 String   @db.Uuid @map("user_id")
  provider               String   // e.g., 'stripe', 'paddle', 'custom'
  providerSubscriptionId String   @unique @map("provider_subscription_id")
  planId                 String   @map("plan_id") // e.g., 'pro_plan' or external product ID
  status                 String   // 'active', 'canceled', 'past_due'
  currentPeriodEnd       DateTime @map("current_period_end")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // A user can have multiple active entitlements (e.g., 'pro_plan' + 'ai_addon')
  @@map("entitlements")
}

